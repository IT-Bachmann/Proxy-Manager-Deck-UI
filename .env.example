PROXYDECK_ADMIN_USER=admin
PROXYDECK_ADMIN_PASSWORD=replace-this-with-at-least-16-random-characters
PROXYDECK_BIND_ADDRESS=0.0.0.0
PROXYDECK_BIND_ADDRESS_IPV6=::
# Erzeugen mit: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PROXYDECK_SECRET_KEY=replace-with-a-fernet-key
# Auf 1 setzen, sobald das Dashboard selbst ausschließlich per HTTPS erreichbar ist.
PROXYDECK_SECURE_COOKIE=0
